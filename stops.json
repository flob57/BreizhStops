* {
  box-sizing: border-box;
}

:root {
  --blue: #004b87;
  --blue-dark: #003965;
  --background: #eef2f6;
  --panel: #ffffff;
  --text: #1f2933;
  --muted: #5b6773;
  --border: #d9e0e7;
  --soft: #fbfcfd;
  --secondary: #6b7280;
}

html,
body {
  margin: 0;
  min-height: 100%;
  font-family: Arial, Helvetica, sans-serif;
  background: var(--background);
  color: var(--text);
}

header {
  min-height: 64px;
  background: var(--blue);
  color: white;
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 16px;
  padding:
    max(12px, env(safe-area-inset-top))
    22px
    12px;
}

header h1 {
  margin: 0;
  font-size: 22px;
}

#status {
  font-size: 14px;
  opacity: 0.92;
  white-space: nowrap;
}

.layout {
  display: grid;
  grid-template-columns: 380px minmax(0, 1fr) 360px;
  grid-template-rows: auto minmax(0, 1fr);
  grid-template-areas:
    "search map route"
    "results map route";
  height: calc(100vh - 64px);
}

.search-tools {
  grid-area: search;
  background: var(--panel);
  padding: 16px 16px 6px;
  border-right: 1px solid var(--border);
}

.results-panel {
  grid-area: results;
  background: var(--panel);
  padding: 6px 16px 16px;
  overflow-y: auto;
  border-right: 1px solid var(--border);
}

.map-panel {
  grid-area: map;
  min-width: 0;
  min-height: 0;
}

#map {
  width: 100%;
  height: 100%;
  min-height: 300px;
}

.route-panel {
  grid-area: route;
  background: var(--panel);
  padding: 16px;
  overflow-y: auto;
  border-left: 1px solid var(--border);
}

.route-panel h2 {
  margin-top: 0;
}

.route-panel h3 {
  margin-top: 22px;
  margin-bottom: 10px;
}

input,
select {
  width: 100%;
  padding: 13px;
  font-size: 15px;
  border: 1px solid #ccd3da;
  border-radius: 10px;
  background: white;
}

#search {
  margin-bottom: 10px;
}

.filters {
  display: grid;
  grid-template-columns: 1fr;
  gap: 10px;
}

#counter {
  margin: 10px 0 14px;
  color: var(--muted);
  font-size: 14px;
}

.result {
  padding: 13px;
  border: 1px solid #e3e8ee;
  border-radius: 12px;
  margin-bottom: 10px;
  background: var(--soft);
}

.result:hover {
  background: #f0f6fc;
}

.result strong {
  font-size: 16px;
}

.meta {
  margin: 6px 0 10px;
  color: var(--muted);
  font-size: 14px;
}

button,
.map-link {
  display: inline-block;
  margin: 4px 5px 4px 0;
  padding: 9px 11px;
  border-radius: 8px;
  border: none;
  background: var(--blue);
  color: white;
  cursor: pointer;
  text-decoration: none;
  font-size: 13px;
}

button:hover,
.map-link:hover {
  background: var(--blue-dark);
}

button:disabled {
  background: #b8c0c8;
  cursor: not-allowed;
}

.secondary {
  background: var(--secondary);
}

.empty {
  color: #777;
  font-style: italic;
}

.popup-title {
  font-weight: bold;
  margin-bottom: 5px;
}

.departure-options {
  margin: 0;
  padding: 12px;
  border: 1px solid var(--border);
  border-radius: 12px;
}

.departure-options legend {
  padding: 0 6px;
  font-weight: bold;
}

.departure-options label {
  display: flex;
  align-items: center;
  gap: 9px;
  padding: 7px 0;
  cursor: pointer;
}

.departure-options input[type="radio"] {
  width: auto;
  margin: 0;
}

.information-box {
  margin-top: 12px;
  padding: 11px;
  border-radius: 9px;
  background: #eef6fc;
  color: #31536d;
  font-size: 13px;
}

.start-stop-area {
  margin-top: 15px;
}

.start-stop-area > label {
  display: block;
  margin-bottom: 7px;
  font-weight: bold;
}

.hidden {
  display: none;
}

.start-result {
  padding: 9px;
  margin-top: 6px;
  border: 1px solid #dfe5eb;
  border-radius: 8px;
  background: var(--soft);
  cursor: pointer;
}

.start-result:hover {
  background: #eef6fc;
}

.selected-start {
  margin-top: 10px;
  padding: 11px;
  background: #eaf7ef;
  border: 1px solid #b9dfc7;
  border-radius: 9px;
}

.route-item {
  padding: 11px 0;
  border-bottom: 1px solid #e5e9ee;
}

.route-item-buttons {
  display: flex;
  flex-wrap: wrap;
  gap: 4px;
  margin-top: 7px;
}

.route-item-buttons button {
  margin: 0;
}

.route-actions {
  display: grid;
  gap: 8px;
  margin-top: 16px;
}

.route-actions button {
  width: 100%;
  margin: 0;
  padding: 11px;
  font-weight: bold;
}

@media (max-width: 1000px) {
  .layout {
    grid-template-columns: 1fr;
    grid-template-rows: auto 420px auto auto;
    grid-template-areas:
      "search"
      "map"
      "route"
      "results";
    height: auto;
  }

  .search-tools {
    border-right: none;
    border-bottom: 1px solid var(--border);
    padding: 16px;
  }

  .map-panel {
    height: 420px;
  }

  .route-panel {
    border-left: none;
    border-top: 1px solid var(--border);
    border-bottom: 1px solid var(--border);
    overflow: visible;
  }

  .results-panel {
    border-right: none;
    overflow: visible;
    padding: 16px;
  }
}

@media (max-width: 600px) {
  header {
    padding:
      max(12px, env(safe-area-inset-top))
      16px
      12px;
  }

  header h1 {
    font-size: 19px;
  }

  #status {
    font-size: 13px;
  }

  .layout {
    grid-template-rows: auto 340px auto auto;
  }

  .map-panel {
    height: 340px;
  }

  input,
  select {
    font-size: 16px;
  }

  button,
  .map-link {
    font-size: 14px;
    padding: 10px 12px;
  }
}
